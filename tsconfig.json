{
  "compilerOptions": {
    "target": "es2022",
    "module": "node20",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "types": ["node"],
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/**/*.ts"]
}