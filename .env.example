# Auth (configure at least one bearer mechanism outside explicit insecure dev mode)
# API_KEY=your-secret-key-here
# JWT_SECRET=your-hs256-signing-key-here
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_JWKS={"keys":[{"kty":"RSA","n":"...","e":"AQAB","alg":"RS256","use":"sig","kid":"rotation-primary"}]}
# JWT_JWKS_URL=https://issuer.example.test/.well-known/jwks.json
# Configure exactly one of JWT_SECRET, JWT_PUBLIC_KEY, JWT_JWKS, or JWT_JWKS_URL for JWT bearer auth.
# When JWT_JWKS_URL is used, JWT_ISSUER must be an absolute https issuer URL on the same origin.
# JWT_ISSUER=https://issuer.example.test
# JWT_AUDIENCE=anamnesis-api
# JWT_TYP=anamnesis+jwt

# Runtime
PORT=4020
# NODE_ENV=development
# RATE_LIMIT_RPM=300
# ALLOW_INSECURE_DEV_AUTH=true
# EXTERNAL_ATTACHMENT_HOST_ALLOWLIST=records.example.org,cdn.example.org

# Optional draft-only LLM sidecar (OpenAI-compatible /v1/chat/completions)
# LLM_SIDECAR_BASE_URL=http://127.0.0.1:11434
# LLM_SIDECAR_MODEL=local-clinician-draft-model
# LLM_SIDECAR_API_KEY=optional-sidecar-bearer-token
# LLM_SIDECAR_TIMEOUT_MS=5000

# Durable persistence (SQLite + AES-256-GCM encryption at rest)
# STORE_PATH=./data/anamnesis.db
# ENCRYPTION_KEY=<64-hex-characters — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">