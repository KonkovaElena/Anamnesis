{
  "name": "anamnesis-control-plane",
  "version": "1.0.0",
  "private": true,
  "author": "Anamnesis contributors",
  "description": "Clinician-in-the-loop personal health control plane bootstrap",
  "homepage": "https://github.com/KonkovaElena/Anamnesis#readme",
  "bugs": {
    "url": "https://github.com/KonkovaElena/Anamnesis/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KonkovaElena/Anamnesis.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11",
      "onFail": "warn"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "keywords": [
    "healthcare",
    "clinician-in-the-loop",
    "anamnesis",
    "typescript",
    "express"
  ],
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
